rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------
    // USERS
    // Chaque utilisateur ne peut lire/écrire que son propre doc
    // -----------------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // -----------------------------------------------------
    // FAMILIES
    // On verrouille complètement la lecture directe des familles
    // (on utilise les invitations pour rejoindre)
    // -----------------------------------------------------
    match /families/{familyId} {
      // Doc public minimal
      allow read, write, delete: if request.auth != null
                                 && request.auth.uid in resource.data.ownerIds;

      // Membres
      match /members/{memberId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == memberId;
      }

      // Privé (nom de famille)
      match /private/{doc} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.ownerIds;
      }
    }

    // -----------------------------------------------------
    // INVITES (general + reconnect)
    // -----------------------------------------------------
    match /invites/general/{code} {
      allow create, get: if request.auth != null;
      allow update, delete: if false;
    }

    match /invites/reconnect/{code} {
      allow create, get: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Helpers ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isParentOf(familyId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.ownerIds;
    }

    function isMemberOf(familyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isChildOwner(familyId, docId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'child' &&
        request.auth.uid == get(/databases/$(database)/documents/families/$(familyId)/members/$(docId)).data.linkedAuthUid;
    }

    // ── TRANSITION DÉMO ──────────────────────────────────────
    // famille_demo reste accessible sans auth pendant la transition
    // vers le Lot 0-SEC complet (onboarding multi-famille)
    // À SUPPRIMER une fois l'onboarding implémenté
    match /families/famille_demo/{document=**} {
      allow read, write: if true;
    }

    // ── Anti-énumération ─────────────────────────────────────
    // Impossible de lister /families sans familyId exact
    match /families/{familyId} {
      allow list:   if false;
      allow get:    if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isAuth();
      allow update: if isParentOf(familyId);
      allow delete: if isParentOf(familyId);
    }

    // ── Membres ──────────────────────────────────────────────
    match /families/{familyId}/members/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isAuth();
      allow update: if isParentOf(familyId) ||
        // Enfant peut mettre à jour uniquement son propre profil (avatar, mdp)
        (isAuth() && request.auth.uid ==
          get(/databases/$(database)/documents/families/$(familyId)/members/$(userId)).data.linkedAuthUid &&
          request.resource.data.keys().hasOnly(['avatarSkin','childPasswordHash','updatedAt']));
      allow delete: if isParentOf(familyId);
    }

    // ── Scores — seul le parent écrit ────────────────────────
    match /families/{familyId}/scores/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Économie — seul le parent écrit ──────────────────────
    match /families/{familyId}/economy/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Missions — parent écrit, enfant lit ──────────────────
    match /families/{familyId}/missions/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Avatars — enfant peut écrire les siens ───────────────
    match /families/{familyId}/avatars/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId) ||
        (isAuth() && request.auth.uid ==
          get(/databases/$(database)/documents/families/$(familyId)/members/$(userId)).data.linkedAuthUid);
    }

    // ── Catalogue missions — parent gère, tous lisent ────────
    match /families/{familyId}/missionCatalog/{missionId} {
      allow read:   if isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Boutique ─────────────────────────────────────────────
    match /families/{familyId}/shop/{itemId} {
      allow read:   if isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Demandes d'achat ─────────────────────────────────────
    match /families/{familyId}/shop/{itemId}/purchaseRequests/{reqId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isMemberOf(familyId);
      allow update: if isParentOf(familyId);
      allow delete: if isParentOf(familyId);
    }

    // ── Tokens d'invitation ──────────────────────────────────
    // Lecture publique pour validation (token = seul accès possible)
    // Écriture réservée aux parents de la famille
    match /families/{familyId}/invites/{tokenId} {
      allow read:   if true;   // Nécessaire pour valider un token sans être authentifié
      allow create: if isParentOf(familyId) || isAuth(); // Création famille = pas encore parent
      allow update: if isAuth(); // Consommation du token
      allow delete: if isParentOf(familyId);
    }
  }
}
