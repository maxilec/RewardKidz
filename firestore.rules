rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ─────────────────────────────────────────────
    // Chaque utilisateur peut lire/écrire uniquement son propre document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Un parent peut supprimer le doc d'un membre lors de la suppression de la famille
      // Un enfant qui se reconnecte peut supprimer son ancienne session anonyme :
      //   le doc reconnectPublic pointe encore vers l'ancien UID au moment du batch
      allow delete: if isAuth() && resource.data.familyId != null && (
        isParentOf(resource.data.familyId) ||
        // Reconnexion via PIN legacy (reconnectPublic)
        (resource.data.memberId != null &&
         exists(/databases/$(database)/documents/families/$(resource.data.familyId)/reconnectPublic/$(resource.data.memberId)) &&
         get(/databases/$(database)/documents/families/$(resource.data.familyId)/reconnectPublic/$(resource.data.memberId)).data.linkedAuthUid == userId) ||
        // Reconnexion via OTP enfant (childOTPs sous-collection encore présent au batch)
        (resource.data.memberId != null &&
         exists(/databases/$(database)/documents/families/$(resource.data.familyId)/childOTPs/$(resource.data.memberId)))
      );
    }


    // ── Helpers ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isParentOf(familyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == "parent";
    }

    // isMemberOf via user doc (compatible avec memberId ≠ UID)
    function isMemberOf(familyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    // ── TRANSITION DÉMO ──────────────────────────────────────
    // famille_demo reste accessible sans auth pendant la transition
    // À SUPPRIMER une fois l'onboarding implémenté
    match /families/famille_demo/{document=**} {
      allow read, write: if true;
    }

    // ── Anti-énumération ─────────────────────────────────────
    // Impossible de lister /families sans familyId exact
    match /families/{familyId} {
      allow list:   if false;
      allow get:    if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isAuth();
      allow update: if isParentOf(familyId);
      allow delete: if isParentOf(familyId);
    }

    // ── Membres ──────────────────────────────────────────────
    match /families/{familyId}/members/{memberId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isAuth();
      allow update: if isParentOf(familyId) ||
        // Enfant met à jour son profil (avatar, PIN)
        (isAuth() && request.auth.uid == resource.data.linkedAuthUid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['avatarSkin','childPasswordHash','updatedAt'])) ||
        // Reconnexion legacy (PIN) : update uniquement linkedAuthUid
        (isAuth() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedAuthUid']) &&
         exists(/databases/$(database)/documents/families/$(familyId)/reconnectPublic/$(memberId))) ||
        // Connexion / reconnexion via OTP enfant
        (isAuth() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedAuthUid']) &&
         exists(/databases/$(database)/documents/families/$(familyId)/childOTPs/$(memberId)));
      allow delete: if isParentOf(familyId);
    }

    // ── Reconnexion publique ─────────────────────────────────
    match /families/{familyId}/reconnectPublic/{memberId} {
      allow read:   if true; // Lecture publique pour valider prénom + PIN
      allow create: if isAuth();
      // Reconnexion : mise à jour de linkedAuthUid par le nouvel utilisateur anonyme
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedAuthUid']);
      allow delete: if isParentOf(familyId);
    }

    // ── Scores — seul le parent écrit ────────────────────────
    match /families/{familyId}/scores/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Économie — seul le parent écrit ──────────────────────
    match /families/{familyId}/economy/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Missions — parent écrit, enfant lit ──────────────────
    match /families/{familyId}/missions/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Avatars — enfant peut écrire les siens ───────────────
    match /families/{familyId}/avatars/{userId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow write:  if isParentOf(familyId) ||
        (isAuth() && request.auth.uid == resource.data.linkedAuthUid);
    }

    // ── Catalogue missions — parent gère, tous lisent ────────
    match /families/{familyId}/missionCatalog/{missionId} {
      allow read:   if isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Boutique ─────────────────────────────────────────────
    match /families/{familyId}/shop/{itemId} {
      allow read:   if isMemberOf(familyId);
      allow write:  if isParentOf(familyId);
    }

    // ── Demandes d'achat ─────────────────────────────────────
    match /families/{familyId}/shop/{itemId}/purchaseRequests/{reqId} {
      allow read:   if isParentOf(familyId) || isMemberOf(familyId);
      allow create: if isMemberOf(familyId);
      allow update: if isParentOf(familyId);
      allow delete: if isParentOf(familyId);
    }

    // ── Tokens d'invitation (top-level, lookup par code sans connaître familyId) ──
    match /invites/{tokenId} {
      allow read:   if true; // Lecture publique pour valider un code sans être authentifié
      allow create: if isAuth() && (isParentOf(request.resource.data.familyId) ||
                                    isMemberOf(request.resource.data.familyId));
      allow delete: if isAuth() && (isParentOf(resource.data.familyId) ||
                                    isMemberOf(resource.data.familyId));
    }

    // ── Tokens d'invitation (imbriqués, héritage legacy) ────────────────────────
    match /families/{familyId}/invites/{tokenId} {
      allow read:   if true;
      allow create: if isParentOf(familyId) || isAuth();
      allow update: if isAuth();
      allow delete: if isParentOf(familyId);
    }

    // ── OTP enfants (top-level, lookup par code sans connaître familyId) ──
    match /childOTPs/{otpCode} {
      allow read:   if true; // Lecture publique pour valider le code depuis l'appareil enfant
      allow create: if isParentOf(request.resource.data.familyId);
      allow delete: if isAuth();
    }

    // ── OTP enfants (sous-collection, existence check pour les règles) ──
    match /families/{familyId}/childOTPs/{memberId} {
      allow read:   if true;
      allow create: if isParentOf(familyId);
      allow delete: if isAuth();
    }

    // ── Index codes famille permanents ────────────────────────
    match /familyCodes/{code} {
      allow read:   if true; // Lecture publique pour résoudre un code famille
      allow create: if isAuth();
      allow delete: if isAuth() && isMemberOf(resource.data.familyId);
    }
  }
}
