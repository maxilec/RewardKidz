rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PHASE DÉMO ──────────────────────────────────────────
    // Accès complet sur la famille de démo
    // Le contrôle d'accès est géré côté client par le PIN hashé
    // Lot 0-SEC : remplacer par les règles strictes avec Firebase Auth

    match /families/famille_demo/{document=**} {
      allow read, write: if true;
    }

    // ── AUTRES FAMILLES — bloquées ───────────────────────────
    match /families/{familyId}/{document=**} {
      allow read, write: if false;
    }
  }
}
