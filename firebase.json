{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      ".gitignore",
      ".github/**",
      "*.md",
      "firebase.config.example.js",
      "firebase.config.js"
    ],
    "rewrites": [
      {
        "source": "/app",
        "destination": "/app.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
