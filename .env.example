# Copier ce fichier en .env.local et remplir les valeurs
# NE PAS committer .env.local (dans .gitignore)
# Les valeurs réelles sont injectées par GitHub Actions via .env.production

VITE_FIREBASE_API_KEY=VOTRE_API_KEY
# ⚠️  authDomain = domaine Firebase Hosting (pas firebaseapp.com)
# Utiliser : rewardkidz-4fe68.web.app  pour que l'auth iOS fonctionne
VITE_FIREBASE_AUTH_DOMAIN=rewardkidz-4fe68.web.app
VITE_FIREBASE_PROJECT_ID=rewardkidz-4fe68
VITE_FIREBASE_STORAGE_BUCKET=rewardkidz-4fe68.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=VOTRE_SENDER_ID
VITE_FIREBASE_APP_ID=VOTRE_APP_ID
# Clé VAPID pour les push notifications (Firebase Console → Project Settings → Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=VOTRE_VAPID_KEY
